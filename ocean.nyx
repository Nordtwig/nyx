[resource]
script = ExtResource("2_axjmy")
exported_shader_path = "res://ocean.gdshader"
compiled_code = "// nyx_source: res://ocean.nyx
// This shader was generated by Nyx. To edit it visually, right-click
// this file in the FileSystem dock and choose \"Open in Nyx\" (for now).
shader_type spatial;
render_mode blend_mix;
uniform float ripple_normal_strength : hint_range(0.0000, 1.0000) = 2.0000;
uniform float fbm1_scale : hint_range(0.0000, 1.0000) = 2.5000;
uniform float fbm2_scale : hint_range(0.0000, 1.0000) = 7.0000;
uniform float fbm_breakup_scale : hint_range(0.0000, 1.0000) = 4.0000;
uniform float breakup_edge0 : hint_range(0.0000, 1.0000) = 0.4200;
uniform float breakup_edge1 : hint_range(0.0000, 1.0000) = 0.6500;
uniform float crest_edge0 : hint_range(0.0000, 1.0000) = 0.5000;
uniform float crest_edge1 : hint_range(0.0000, 1.0000) = 0.8500;
uniform sampler2D DEPTH_TEXTURE : hint_depth_texture, filter_nearest;
uniform float depth_shore_distance : hint_range(0.0000, 1.0000) = 0.8000;
uniform float depth_body_distance : hint_range(0.0000, 1.0000) = 4.0000;
uniform sampler2D grad_watergradient : source_color, hint_default_white;
uniform vec4 horizon_color : source_color;
uniform float fresnel_horizon_power : hint_range(0.0000, 1.0000) = 4.0000;
uniform vec4 foam_white_color : source_color;
uniform float rough_base : hint_range(0.0000, 1.0000) = 0.0800;
uniform float rough_foam : hint_range(0.0000, 1.0000) = 0.4500;
uniform float specular : hint_range(0.0000, 1.0000) = 0.0500;
uniform float ripple_strength : hint_range(0.0000, 1.0000) = 0.0400;
uniform sampler2D SCREEN_TEXTURE : hint_screen_texture, filter_linear_mipmap;
uniform float depth_refraction_distance : hint_range(0.0000, 1.0000) = 2.5000;
uniform float fresnel_glow_power : hint_range(0.0000, 1.0000) = 1.5000;
uniform float glow_strength : hint_range(0.0000, 1.0000) = 0.4000;
uniform vec4 sss_color : source_color;

float nyx_ocean_hash(float n) {
	return fract(sin(n) * 43758.5453123);
}
vec3 nyx_ocean_offset(vec3 wp, float t, int count, float wavelength, float amplitude, float steepness, float speed, float direction, float spread, float seed) {
	vec2 p = wp.xz;
	vec3 o = vec3(0.0);
	float base = radians(direction);
	float fcount = float(count);
	for (int i = 0; i < count; i++) {
		float fi = float(i);
		float k = 6.28318530718 / (wavelength * pow(0.68, fi));
		float a = amplitude * pow(0.62, fi);
		float ang = base + radians(spread) * (nyx_ocean_hash(seed + fi * 13.13) * 2.0 - 1.0);
		vec2 d = vec2(cos(ang), sin(ang));
		float ph = k * dot(d, p) - sqrt(9.8 * k) * speed * t;
		float qa = steepness / (fcount * k);
		o.x += d.x * qa * cos(ph);
		o.z += d.y * qa * cos(ph);
		o.y += a * sin(ph);
	}
	return o;
}
vec3 nyx_ocean_normal(vec3 wp, float t, int count, float wavelength, float amplitude, float steepness, float speed, float direction, float spread, float seed) {
	vec2 p = wp.xz;
	float nx = 0.0;
	float nz = 0.0;
	float ny = 0.0;
	float base = radians(direction);
	float fcount = float(count);
	for (int i = 0; i < count; i++) {
		float fi = float(i);
		float k = 6.28318530718 / (wavelength * pow(0.68, fi));
		float a = amplitude * pow(0.62, fi);
		float ang = base + radians(spread) * (nyx_ocean_hash(seed + fi * 13.13) * 2.0 - 1.0);
		vec2 d = vec2(cos(ang), sin(ang));
